# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# WalletConnect Cloud project ID (optional — leave blank to skip)
NEXT_PUBLIC_WC_PROJECT_ID=

# Pinata gateway for IPFS reads (default works without a key)
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs/

# Sepolia RPC for read-only queries from the browser
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Pinata JWT — server-side only. Get one at https://app.pinata.cloud (Account → API Keys).
# Without this, story/cover/update/voucher uploads fall back to deterministic fake CIDs
# and the campaign page will not be able to resolve the metadata.
PINATA_JWT=
