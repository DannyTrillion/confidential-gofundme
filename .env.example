# =========================================================
# Confidential GoFundMe — environment variables
# Copy values you need into apps/web/.env.local and packages/contracts/.env
# =========================================================

# ----- Contracts (packages/contracts/.env) -----
# RPC for Sepolia (FHEVM testnet — chainId 11155111).
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Private key of the deployer wallet (DO NOT commit). Hex without 0x prefix is also fine.
DEPLOYER_PRIVATE_KEY=0xabc...
# Etherscan API key for `npx hardhat verify`.
ETHERSCAN_API_KEY=
# Optional: override the Sepolia ETH/USD Chainlink feed (defaults to 0x694AA1769357215DE4FAC081bf1f309aDC325306).
ETH_USD_FEED=
# Initial USD->NGN rate, scaled by 1e8 (e.g. 1500 NGN/USD => 150000000000). Admin can update later.
INITIAL_USD_NGN_1E8=150000000000

# ----- Web app (apps/web/.env.local) -----
# WalletConnect Cloud project ID — https://cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID=
# Pinata JWT (Account → API Keys → New Key → "Admin"). Used server-side only.
PINATA_JWT=
# Public Pinata gateway (defaults to https://gateway.pinata.cloud/ipfs/).
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs/
# Public RPC the browser uses (read-only OK; signing uses the wallet's RPC).
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
